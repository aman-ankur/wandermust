# LLM — set ONE of these (OpenAI preferred, OpenRouter as alternative)
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# LLM model names (defaults: gpt-4o for main, gpt-4o-mini for extraction)
# LLM_MODEL=gpt-4o
# DISCOVERY_MODEL=gpt-4o
# SOCIAL_EXTRACTION_MODEL=gpt-4o-mini

# SerpApi (https://serpapi.com) — for flights + hotels via Google
SERPAPI_API_KEY=your_serpapi_key

# Defaults
DEFAULT_ORIGIN=Bangalore
DEFAULT_CURRENCY=INR

# Social insights (optional)
TAVILY_API_KEY=your_tavily_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
